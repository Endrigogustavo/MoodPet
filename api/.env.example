# ── MoodPet API — Environment Variables ──────────────────────────────────────

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite+aiosqlite:///./moodpet.db

# AI Provider (choose one or both)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Emotion Detection
EMOTION_CONFIDENCE_THRESHOLD=0.45
NO_FACE_ALERT_TIMEOUT_MINUTES=10
FRAME_PROCESS_INTERVAL_MS=500

# Alerts
ENABLE_EMAIL_ALERTS=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Emergency Contact
EMERGENCY_CONTACT_EMAIL=contact@example.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
EMERGENCY_PHONE=

# Music Service
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Security
SECRET_KEY=change_this_to_a_random_secret_key_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
